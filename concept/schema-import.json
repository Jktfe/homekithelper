{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HomeKit Import Change Set",
  "description": "A change set generated by the web app to be applied by the native bridge.",
  "type": "object",
  "required": ["homeId"],
  "properties": {
    "homeId": {
      "type": "string",
      "description": "UUID of the target home"
    },
    "renames": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["accessoryId", "currentName", "newName"],
        "properties": {
          "accessoryId": { "type": "string" },
          "currentName": { "type": "string" },
          "newName": { "type": "string" }
        }
      }
    },
    "roomAssignments": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["accessoryId"],
        "properties": {
          "accessoryId": { "type": "string" },
          "newRoomId": { "type": "string" },
          "newRoomName": { "type": "string" }
        }
      }
    },
    "newRooms": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["roomName"],
        "properties": {
          "roomName": { "type": "string" },
          "zone": { "type": "string" }
        }
      }
    },
    "deleteRooms": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["roomId"],
        "properties": {
          "roomId": { "type": "string", "description": "UUID of the room to delete" }
        }
      }
    },
    "newScenes": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["sceneName", "actions"],
        "properties": {
          "sceneName": { "type": "string" },
          "actions": {
            "type": "array",
            "items": { "$ref": "#/$defs/sceneAction" }
          }
        }
      }
    },
    "deleteScenes": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["sceneId"],
        "properties": {
          "sceneId": { "type": "string", "description": "UUID of the scene to delete" }
        }
      }
    },
    "updateScenes": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["sceneId", "actions"],
        "properties": {
          "sceneId": { "type": "string", "description": "UUID of the scene to update" },
          "newSceneName": { "type": "string", "description": "Optional new name for the scene" },
          "actions": {
            "type": "array",
            "description": "New actions that replace all existing actions",
            "items": { "$ref": "#/$defs/sceneAction" }
          }
        }
      }
    },
    "newZones": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["zoneName"],
        "properties": {
          "zoneName": { "type": "string" }
        }
      }
    },
    "deleteZones": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["zoneId"],
        "properties": {
          "zoneId": { "type": "string", "description": "UUID of the zone to delete" }
        }
      }
    }
  },
  "$defs": {
    "sceneAction": {
      "type": "object",
      "required": ["accessoryId", "serviceType", "characteristicType", "targetValue"],
      "properties": {
        "accessoryId": { "type": "string" },
        "serviceType": { "type": "string" },
        "characteristicType": { "type": "string" },
        "targetValue": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "integer" },
            { "type": "number" },
            { "type": "string" }
          ]
        }
      }
    }
  }
}
